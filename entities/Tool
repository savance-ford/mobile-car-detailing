{
  "name": "Tool",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Tool/software name"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly slug"
    },
    "category_slug": {
      "type": "string",
      "description": "Category this tool belongs to"
    },
    "short_description": {
      "type": "string",
      "description": "One-line description for cards"
    },
    "long_description": {
      "type": "string",
      "description": "Full SEO content (800-1200 words)"
    },
    "logo_url": {
      "type": "string",
      "description": "Logo image URL"
    },
    "affiliate_url": {
      "type": "string",
      "description": "Affiliate tracking link"
    },
    "official_url": {
      "type": "string",
      "description": "Official website URL"
    },
    "pricing_starts_at": {
      "type": "string",
      "description": "Starting price display string"
    },
    "pricing_details": {
      "type": "string",
      "description": "Full pricing breakdown"
    },
    "rating": {
      "type": "number",
      "description": "Rating out of 5"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Key features list"
    },
    "pros": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Advantages"
    },
    "cons": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Disadvantages"
    },
    "best_for": {
      "type": "string",
      "description": "Who this tool is best for"
    },
    "feature_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Feature tags for filtering (scheduling, crm, invoicing, etc.)"
    },
    "faqs": {
      "type": "array",
      "description": "FAQ items",
      "items": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string"
          },
          "answer": {
            "type": "string"
          }
        }
      }
    },
    "is_featured": {
      "type": "boolean",
      "description": "Show on homepage"
    },
    "sort_order": {
      "type": "number",
      "description": "Display order"
    }
  },
  "required": [
    "name",
    "slug"
  ]
}